{
  "name": "release-notes-writer",
  "description": "Pure reasoner: given a JSON list of triaged bugs+fixes, composes release notes. Touches no tables — gather_release_data reads, persist_release_notes writes.",
  "instruction": { "$file": "instruction.md" },
  "toolsets": ["POD"],
  "visibility": "POD",
  "input_schema": {
    "type": "object",
    "properties": {
      "bugs": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "bug_type": { "type": "string" },
            "severity": { "type": "string" },
            "reasoning": { "type": "string" },
            "fix_title": { "type": "string" },
            "fix_suggestion": { "type": "string" },
            "risk_level": { "type": "string" },
            "estimated_effort": { "type": "string" }
          }
        }
      }
    },
    "required": ["bugs"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "notes_markdown": { "type": "string" },
      "highlights": { "type": "array", "items": { "type": "string" } },
      "breaking_changes": { "type": "array", "items": { "type": "string" } }
    },
    "required": ["notes_markdown", "highlights", "breaking_changes"]
  },
  "permissions": { "grants": [] }
}
