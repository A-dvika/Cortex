{
  "name": "incidents",
  "primary_key_column": "id",
  "enable_rls": false,
  "visibility": "POD",
  "columns": [
    { "name": "source", "type": "ENUM", "required": true, "default": "manual",
      "options": ["github", "webhook", "monitoring", "manual"] },
    { "name": "title", "type": "TEXT", "required": true, "max_length": 300 },
    { "name": "summary", "type": "TEXT" },
    { "name": "severity", "type": "ENUM", "required": true, "default": "P3",
      "options": ["P1", "P2", "P3"] },
    { "name": "status", "type": "ENUM", "required": true, "default": "open",
      "options": ["open", "acked", "resolved"] },
    { "name": "bug_id", "type": "UUID", "foreign_key": { "references": "bugs.id" } },
    { "name": "assignee_login", "type": "TEXT", "max_length": 120 },
    { "name": "escalation_level", "type": "INTEGER", "default": 0 },
    { "name": "alert_channel_msg", "type": "TEXT" },
    { "name": "acked_at", "type": "DATETIME" },
    { "name": "resolved_at", "type": "DATETIME" }
  ],
  "config": {}
}
