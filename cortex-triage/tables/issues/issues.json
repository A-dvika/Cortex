{
  "name": "issues",
  "primary_key_column": "id",
  "enable_rls": false,
  "visibility": "POD",
  "columns": [
    { "name": "source", "type": "ENUM", "required": true, "default": "manual",
      "options": ["github", "slack", "email", "manual"] },
    { "name": "external_id", "type": "TEXT", "max_length": 120 },
    { "name": "title", "type": "TEXT", "required": true, "max_length": 300 },
    { "name": "body", "type": "TEXT" },
    { "name": "url", "type": "TEXT", "max_length": 600 },
    { "name": "reporter", "type": "TEXT", "max_length": 200 },
    { "name": "triage_status", "type": "ENUM", "required": true, "default": "pending",
      "options": ["pending", "triaged", "done"] }
  ],
  "config": {}
}
